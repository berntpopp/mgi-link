# mgi-link configuration (copy to .env). All vars use the MGI_LINK_ prefix.
# Nested config uses a double underscore, e.g. MGI_LINK_DATA__DB_FILENAME.

# --- Server ---
# MGI_LINK_HOST=127.0.0.1
# MGI_LINK_PORT=8000
# MGI_LINK_TRANSPORT=unified           # unified | http | stdio
# JSON lists. Add the exact public reverse-proxy hostname in production.
# MGI_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
# MGI_LINK_ALLOWED_ORIGINS=[]
# MGI_LINK_LOG_LEVEL=INFO
# MGI_LINK_LOG_FORMAT=console          # console | json

# --- Local data store (MGI bulk reports -> SQLite index) ---
# MGI_LINK_DATA__DATA_DIR=./data
# MGI_LINK_DATA__REPORTS_BASE_URL=https://www.informatics.jax.org/downloads/reports
# MGI_LINK_DATA__AUTO_BOOTSTRAP=true   # build the DB on first start if absent
# MGI_LINK_DATA__REFRESH_ENABLED=false # cron owns refresh by default
# MGI_LINK_DATA__REFRESH_INTERVAL_HOURS=168  # MGI reports update ~weekly

# --- Live MouseMine enrichment (reserved for v2; off by default) ---
# MGI_LINK_MOUSEMINE__ENABLE_LIVE_FALLBACK=false
# MGI_LINK_MOUSEMINE__CONTACT_EMAIL=you@example.org
# MGI_LINK_MOUSEMINE__RATE_LIMIT_PER_S=2.0
